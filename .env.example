# ---------------------------------------------------------------------------
# HRMS — Environment Variables (template)
# Copy to `.env.local` and fill in real values. NEVER commit `.env.local`.
# ---------------------------------------------------------------------------

# --- Supabase (public, exposed to the browser) ---------------------------
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Publishable / anon key (safe for the client; RLS protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server only, NEVER expose to the browser) -----------------
# Service role key. Used ONLY in trusted server contexts (admin tasks,
# webhooks, seed scripts). Bypasses Row Level Security — handle with care.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ------------------------------------------------------------------
# Canonical site URL (used for auth redirects / email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Default tenant/company timezone & locale for UAE deployments
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Dubai
NEXT_PUBLIC_DEFAULT_CURRENCY=AED
